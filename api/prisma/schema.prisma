// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model File {
  id           String    @id @default(cuid())
  driveFileId  String    @unique
  name         String
  mimeType     String
  webViewLink  String
  thumbnailLink String?
  size         BigInt?   // Size in bytes
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  // Future-proofing fields
  owner   User? @relation(fields: [ownerId], references: [id])
  ownerId String?
  tags    Tag[] @relation("FileTags")

  // Multi-drive support
  driveConfig   DriveConfig? @relation(fields: [driveConfigId], references: [id])
  driveConfigId String?
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  password  String
  role      String   @default("USER")
  roles     Json     @default("[\"STUDENT\"]")
  files     File[]
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
}

model Tag {
  id    String @id @default(cuid())
  name  String @unique
  files File[] @relation("FileTags")
}

model DriveConfig {
  id           String   @id @default(cuid())
  name         String   @default("Default Drive")
  clientId     String
  clientSecret String   // Encrypted
  redirectUri  String
  refreshToken String?  // Encrypted
  folderId     String
  isDefault    Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  files        File[]
}
