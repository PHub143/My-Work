# Neon PostgreSQL Database
# Pooled connection for the application runtime.
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=verify-full&channel_binding=require"

# Direct connection for Prisma schema commands.
DIRECT_URL="postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=verify-full&channel_binding=require"

# Frontend URL for CORS
FRONTEND_URL=http://localhost:5173

# Encryption Key (32 bytes as a 64-character hex string)
ENCRYPTION_KEY=your_64_character_hex_encryption_key_here

# JWT Secret for authentication
JWT_SECRET=your_jwt_secret_key_here

